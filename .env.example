# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql://postgres:password@db.YOUR_PROJECT.supabase.co:5432/postgres

# Stripe (use sk_test_ for local dev, sk_live_ for production)
# Run: STRIPE_SECRET_KEY=sk_test_... npx tsx scripts/sync-stripe-products.ts http://localhost:3000/api/webhooks/stripe
# Then paste the output values below.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...

# Hetzner Cloud
HETZNER_API_TOKEN=...
HETZNER_SSH_KEY_ID=12345

# Vercel AI Gateway (server-side only — never sent to VPS instances)
VERCEL_AI_GATEWAY_KEY=...

# OpenClaw
OPENCLAW_VERSION=2026.3.2

# Instance domain (for ClawPort dashboard URLs)
INSTANCE_DOMAIN=agentcomputers.app

# Cloudflare DNS (optional)
CLOUDFLARE_API_TOKEN=...
CLOUDFLARE_ZONE_ID=...
